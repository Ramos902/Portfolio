---
import pdfLink from "../assets/Joao_Pedro_Ramos_Moraes_Curriculo.pdf";

const navLinks = [
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/joaoramos1512/",
    external: true,
  },
  { label: "GitHub", href: "https://github.com/Ramos902", external: true },
];

const backend = [
  { name: "C# .NET", sub: "APIs REST & arquitetura" },
  { name: "PostgreSQL", sub: "banco relacional" },
  { name: "MySQL", sub: "stored procedures" },
  { name: "Entity Framework", sub: "ORM" },
  { name: "REST APIs", sub: "design & integração" },
];

const frontend = [
  { name: "Angular", sub: "componentes & serviços" },
  { name: "Astro", sub: "SSG & content collections" },
  { name: "HTML + CSS", sub: "layouts responsivos" },
  { name: "JavaScript", sub: "DOM & interatividade" },
  { name: "TypeScript", sub: "tipagem estática" },
];

const devops = [
  { name: "Docker", sub: "containerização" },
  { name: "Git", sub: "versionamento" },
  { name: "PowerShell", sub: "automação Windows" },
  { name: "GitHub Actions", sub: "CI/CD" },
  { name: "Linux", sub: "administração" },
];
---

<section class="sobre" id="sobre">
  <div class="container sobre-inner">
    <div class="sobre-grid">
      <div class="bloco-sobre">
        <span class="section-label-sobre">Sobre</span>
        <p class="sobre-texto">
          Desenvolvedor em formação com foco em backend utilizando .NET (C#),
          com experiência na construção de APIs, manipulação de banco de dados
          SQL e integração com interfaces web. Possuo conhecimentos em frontend
          com frameworks Astro e Angular, buscando evoluir para construção de
          sistemas completos e escaláveis. Atualmente desenvolvendo projetos
          próprios.
        </p>
        <div class="sobre-links">
          {
            navLinks.map((item) => (
              <a
                href={item.href}
                class={`sobre-btn`}
                target={item.external ? "_blank" : undefined}
                rel={item.external ? "noopener noreferrer" : undefined}
              >
                {item.label}
              </a>
            ))
          }
        </div>
      </div>

      <div class="divider-vertical"></div>

      <div class="bloco-stack">
        <span class="section-label-stack">Stack</span>
        <div class="stack-cols">
          <div class="stack-col">
            <p class="col-title red">Backend</p>
            <div class="col-track down">
              {
                [...backend, ...backend].map((item) => (
                  <div class="chip red">
                    <span class="chip-name">{item.name}</span>
                    <span class="chip-sub">{item.sub}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="stack-col">
            <p class="col-title blue">Frontend</p>
            <div class="col-track up">
              {
                [...frontend, ...frontend].map((item) => (
                  <div class="chip blue">
                    <span class="chip-name">{item.name}</span>
                    <span class="chip-sub">{item.sub}</span>
                  </div>
                ))
              }
            </div>
          </div>

          <div class="stack-col">
            <p class="col-title green">DevOps</p>
            <div class="col-track down2">
              {
                [...devops, ...devops].map((item) => (
                  <div class="chip green">
                    <span class="chip-name">{item.name}</span>
                    <span class="chip-sub">{item.sub}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sobre {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    border-top: 1px solid var(--border);
  }

  .sobre-inner {
    width: 100%;
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .sobre-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 4rem;
    align-items: center;
  }

  .section-label-sobre,
  .section-label-stack {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: monospace;
    font-size: 1rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 2rem;
  }

  .section-label-stack::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .section-label-sobre::before {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .sobre-texto {
    color: var(--text-primary);
    font-size: 1.05rem;
    line-height: 1.9;
    margin-bottom: 2.5rem;
    text-align: end;
  }

  .sobre-links {
    display: flex;
    justify-content: end;
    flex-wrap: wrap;
    gap: 10px;
  }

  .sobre-btn {
    font-family: monospace;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 10px 22px;
    border: 1px solid var(--border);
    color: var(--text-primary);
    border-radius: 6px;
    transition:
      border-color 0.2s ease,
      color 0.2s ease;
  }

  .sobre-btn:hover{
    border-color: var(--accent);
    color: var(--accent);
  }

  .divider-vertical {
    width: 1px;
    height: 60%;
    background: var(--border);
    align-self: center;
  }

  /* Stack colunas animadas */
  .stack-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    height: 340px;
  }

  .stack-col {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  .stack-col::before,
  .stack-col::after {
    content: "";
    position: absolute;
    left: 0;
    width: 100%;
    height: 50px;
    z-index: 2;
    pointer-events: none;
  }

  .stack-col::before {
    top: 0;
    background: linear-gradient(to bottom, var(--bg-primary) 30%, transparent);
  }

  .stack-col::after {
    bottom: 0;
    background: linear-gradient(to top, var(--bg-primary) 30%, transparent);
  }

  .col-title {
    font-family: monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: center;
    margin-bottom: 0.5rem;
    flex-shrink: 0;
    position: relative;
    z-index: 4;
    background: var(--bg-primary);
    padding-bottom: 6px;
  }

  .col-title.red {
    color: var(--accent);
  }
  .col-title.blue {
    color: #3b82f6;
  }
  .col-title.green {
    color: #22c55e;
  }

  .col-track {
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .col-track.down {
    animation: scrollUp 18s linear infinite;
  }
  .col-track.up {
    animation: scrollDown 18s linear infinite;
  }
  .col-track.down2 {
    animation: scrollUp 18s linear infinite;
  }
  

  .chip {
    padding: 10px 12px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg-secondary);
    cursor: default;
    flex-shrink: 0;
    transition: border-color 0.2s ease;
  }

  .chip.red:hover {
    border-color: var(--accent);
  }
  .chip.blue:hover {
    border-color: #3b82f6;
  }
  .chip.green:hover {
    border-color: #22c55e;
  }

  .chip-name {
    font-family: monospace;
    font-size: 0.72rem;
    color: var(--text-primary);
    display: block;
    transition: color 0.2s ease;
  }

  .chip.red:hover .chip-name {
    color: var(--accent);
  }
  .chip.blue:hover .chip-name {
    color: #3b82f6;
  }
  .chip.green:hover .chip-name {
    color: #22c55e;
  }

  .chip-sub {
    font-family: monospace;
    font-size: 0.62rem;
    color: var(--text-muted);
    display: block;
    margin-top: 2px;
  }

  @keyframes scrollDown {
    0% {
      transform: translateY(0);
    }
    100% {
      transform: translateY(-50%);
    }
  }

  @keyframes scrollUp {
    0% {
      transform: translateY(-50%);
    }
    100% {
      transform: translateY(0);
    }
  }

  @media (max-width: 900px) {
    .sobre-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .sobre-texto {
      text-align: center;
    }

    .sobre-links {
      justify-content: center;
    }

    .section-label-sobre::after {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .section-label-stack::before {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    .divider-vertical {
      display: none;
    }

    .stack-cols {
      height: 300px;
    }
  }
</style>
