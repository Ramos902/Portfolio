---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import HeaderBlog from "../../components/HeaderBlog.astro";

type Post = CollectionEntry<"blog">;

const posts = (await getCollection("blog")).sort(
    (a: Post, b: Post) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const groups: Record<string, Post[]> = {};
for (const post of posts) {
    const label = post.data.date.toLocaleDateString("pt-BR", {
        year: "numeric",
        month: "long",
    });
    if (!groups[label]) groups[label] = [];
    groups[label].push(post);
}
---

<Layout title="Blog — Ramos">
    <HeaderBlog />

    <main class="blog-main">
        <header class="blog-hero">
            <h1 class="blog-title">Ramos<span class="accent">.blog</span></h1>
            <p class="blog-subtitle">
                Bem-vindo ao meu blog! aqui você vai encontrar anotações sobre o
                que estudo, construo e aprendo - Programação, infraestrutura,
                cyber e às vezes coisas aleatórias.
            </p>
        </header>

        <div class="blog-list" id="blog-list">
            {
                Object.entries(groups).map(([label, groupPosts]) => (
                    <section class="month-group">
                        <h2 class="month-label">{label}</h2>
                        <ul class="post-list">
                            {groupPosts.map((post: Post) => (
                                <li
                                    class="post-item"
                                    data-title={post.data.title.toLowerCase()}
                                    data-body={post.body?.toLowerCase() ?? ""}
                                >
                                    <a
                                        href={`${import.meta.env.BASE_URL}/blog/${post.id}`}
                                        class="post-link"
                                    >
                                        <div class="post-info">
                                            <span class="post-title">
                                                <span class="post-id">
                                                    #{post.data.postId} -{" "}
                                                </span>
                                                {post.data.title}
                                            </span>
                                            <span class="post-desc">
                                                {post.data.description}
                                            </span>
                                        </div>
                                        <span class="post-tags">
                                            {post.data.tags?.map(
                                                (tag: string) => (
                                                    <span class="tag">
                                                        #{tag}
                                                    </span>
                                                ),
                                            )}
                                        </span>
                                    </a>
                                </li>
                            ))}
                        </ul>
                    </section>
                ))
            }
        </div>

        <p class="no-results" id="no-results" style="display:none">
            Nenhum post encontrado.
        </p>
    </main>
</Layout>

<script>
    const input = document.getElementById("blog-search") as HTMLInputElement;
    const noResults = document.getElementById("no-results") as HTMLElement;

    input?.addEventListener("input", () => {
        const query = input.value.toLowerCase().trim();
        const items = document.querySelectorAll<HTMLElement>(".post-item");
        const groups = document.querySelectorAll<HTMLElement>(".month-group");

        items.forEach((item) => {
            const title = item.dataset.title ?? "";
            const body = item.dataset.body ?? "";
            item.style.display =
                !query || title.includes(query) || body.includes(query)
                    ? ""
                    : "none";
        });

        groups.forEach((group) => {
            const hasVisible = [
                ...group.querySelectorAll<HTMLElement>(".post-item"),
            ].some((i) => i.style.display !== "none");
            group.style.display = hasVisible ? "" : "none";
        });

        const anyVisible = [...items].some((i) => i.style.display !== "none");
        noResults.style.display = anyVisible ? "none" : "block";
    });
</script>

<style>
    .blog-main {
        max-width: 720px;
        margin: 0 auto;
        padding: 120px 1.5rem 5rem;
    }

    .blog-hero {
        margin-bottom: 4rem;
        padding-bottom: 2.5rem;
        border-bottom: 1px solid var(--border);
    }

    .blog-title {
        font-family: "Georgia", serif;
        font-size: clamp(2.2rem, 5vw, 3.2rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        color: var(--text-primary);
        margin-bottom: 0.75rem;
        line-height: 1.1;
    }

    .accent {
        color: var(--accent);
    }

    .blog-subtitle {
        font-family: monospace;
        font-size: 0.85rem;
        letter-spacing: 0.04em;
        color: var(--text-muted);
        line-height: 1.6;
    }

    .blog-list {
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    .month-label {
        font-family: monospace;
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border);
    }

    .no-results {
        font-family: monospace;
        font-size: 0.85rem;
        color: var(--text-muted);
        text-align: center;
        padding: 3rem 0;
    }

    :global(.post-list) {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    :global(.post-item) {
        border-bottom: 1px solid
            color-mix(in srgb, var(--border) 50%, transparent);
    }

    :global(.post-item:last-child) {
        border-bottom: none;
    }

    :global(.post-link) {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        padding: 0.9rem 0;
        color: var(--text-primary);
        transition: color 0.15s ease;
        flex-wrap: wrap;
    }

    :global(.post-info) {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        flex: 1;
    }

    :global(.post-title) {
        font-family: "Georgia", serif;
        font-size: 1rem;
        font-weight: 400;
        line-height: 1.4;
        color: var(--text-primary);
        transition: color 0.15s ease;
    }

    :global(.post-id) {
        font-family: "Georgia", serif;
    }

    :global(.post-desc) {
        font-family: monospace;
        font-size: 0.75rem;
        color: var(--text-muted);
        line-height: 1.5;
        font-weight: 400;
        transition: color 0.15s ease;
    }

    :global(.post-tags) {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
        flex-wrap: wrap;
        padding-top: 2px;
    }

    :global(.tag) {
        font-family: monospace;
        font-size: 0.7rem;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        transition: color 0.15s ease;
    }

    :global(.post-link:hover .post-title) {
        color: var(--accent);
    }

    :global(.post-link:hover .post-desc) {
        color: color-mix(in srgb, var(--text-muted) 80%, var(--accent));
    }

    :global(.post-link:hover .tag) {
        color: color-mix(in srgb, var(--accent) 60%, transparent);
    }

    @media (max-width: 600px) {
        :global(.post-tags) {
            display: none;
        }
    }
    @media (max-width: 768px) {
        .blog-main {
            padding-top: 130px;
        }
    }
</style>
